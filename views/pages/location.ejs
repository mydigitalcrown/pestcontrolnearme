<%- include('../partials/head') %>
<%- include('../partials/header') %>

<%- include('../partials/hero') %>

<!-- Trust Bar -->
<div class="trust-bar">
  <div class="container trust-bar-inner">
    <div class="trust-item"><strong>✅</strong><span>Certified Experts</span></div>
    <div class="trust-item"><strong>⚡</strong><span>Same-Day Service</span></div>
    <div class="trust-item"><strong>🛡️</strong><span>3-Month Guarantee</span></div>
    <div class="trust-item"><strong>💰</strong><span>Best Price Promise</span></div>
    <div class="trust-item"><strong>4.9 ★</strong><span>Rated in <%= location.name %></span></div>
  </div>
</div>

<!-- About Section -->
<%- include('../partials/about-section') %>

<!-- Services in this location -->
<section class="services-section section-pad bg-light" aria-label="Services in <%= location.name %>">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Our Services</p>
      <h2 class="section-title">Pest Control Services in <%= location.name %></h2>
      <p class="section-desc">Complete pest management solutions for homes and businesses in <%= location.name %>, <%= location.state %>.</p>
    </div>
    <div class="services-grid">
      <% services.forEach(function(svc) { %>
      <article class="service-card" itemscope itemtype="https://schema.org/Service">
        <div class="service-card-icon"><%= svc.icon %></div>
        <div class="service-card-body">
          <h3 class="service-card-title" itemprop="name"><%= svc.name %> in <%= location.name %></h3>
          <p class="service-card-desc" itemprop="description"><%= svc.shortDesc %></p>
        </div>
        <a href="/services/<%= svc.slug %>" class="service-card-link btn btn-outline" aria-label="<%= svc.name %> services in <%= location.name %>">
          Know More →
        </a>
      </article>
      <% }); %>
    </div>
  </div>
</section>

<!-- CTA 1 -->
<% var ctaVariant = 'primary'; var ctaLocation = location.name; %>
<%- include('../partials/cta') %>

<!-- Location-specific content -->
<section class="section-pad">
  <div class="container">
    <div class="content-grid">
      <div class="content-main">
        <h2>Pest Control in <%= location.name %>, <%= location.state %></h2>
        <p><%= location.desc %></p>
        <p>PestControlNearMe provides professional pest management services across all areas of <%= location.name %>. 
        Our team of certified technicians is well-acquainted with the pest pressures specific to <%= location.name %>'s climate, 
        building types, and urban environment.</p>

        <h3>Why Pest Control is important in <%= location.name %>?</h3>
        <p>With a population of approximately <%= location.population %>, <%= location.name %> presents unique pest management challenges. 
        Dense urban living, tropical/subtropical climate, and rapid construction activity create ideal conditions for 
        cockroaches, termites, mosquitoes, rodents, and other pests to thrive.</p>

        <h3>Areas We Serve in <%= location.name %></h3>
        <p>Our technicians serve all residential societies, commercial complexes, and industrial areas across <%= location.name %> 
        and surrounding areas. Same-day service is available for most locations in the city.</p>

        <h3>What Makes Our Service Different in <%= location.name %>?</h3>
        <ul>
          <li>Local experts with deep knowledge of <%= location.name %>'s pest characteristics</li>
          <li>Treatments customized for <%= location.name %>'s specific climate and building types</li>
          <li>Fast response – most bookings confirmed within 30 minutes</li>
          <li>All services come with a 3-month guarantee</li>
          <li>Transparent pricing – no hidden charges</li>
        </ul>
      </div>
      <div>
        <div class="why-choose-box">
          <h3>Book Pest Control in <%= location.name %></h3>
          <%- include('../partials/contact-form', { compact: true }) %>
        </div>
        <div class="why-choose-box" style="margin-top:1.5rem;">
          <h3>Quick Info – <%= location.name %></h3>
          <ul class="why-list">
            <li><span>🏙️</span> <%= location.name %>, <%= location.state %></li>
            <li><span>👥</span> Population: ~<%= location.population %></li>
            <li><span>⚡</span> Same-Day Service Available</li>
            <li><span>🛡️</span> 3-Month Guarantee</li>
            <li><span>💰</span> Best Price This City</li>
            <li><span>📞</span> 24/7 Emergency Support</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA 2 -->
<% ctaVariant = 'secondary'; %>
<%- include('../partials/cta') %>

<!-- Location-specific FAQ -->
<section class="faq-section section-pad" aria-label="FAQ">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">FAQs</p>
      <h2 class="section-title">Pest Control in <%= location.name %> – FAQ</h2>
    </div>
    <div class="faq-wrapper">
      <% var locationFaqs = [
        { q: 'What is the best pest control company in ' + location.name + '?', a: 'PestControlNearMe is rated the #1 pest control company in ' + location.name + ' with a 4.9-star rating, 200+ certified technicians, and a 3-month service guarantee.' },
        { q: 'How much does pest control cost in ' + location.name + '?', a: 'Pest control costs in ' + location.name + ' depend on the type of service, property size, and severity of infestation. We offer transparent, competitive pricing with no hidden charges. Contact us for a free quote.' },
        { q: 'Do you provide same-day pest control service in ' + location.name + '?', a: 'Yes, we offer same-day pest control services in ' + location.name + ' for most treatments, subject to technician availability. Call us for emergency services.' },
        { q: 'Which areas in ' + location.name + ' do you cover?', a: 'We cover all areas across ' + location.name + ' and surrounding regions. Our technicians are strategically located across the city for fast response.' },
        { q: 'Is your pest control service safe for kids and pets in ' + location.name + '?', a: 'Yes, all treatments done in ' + location.name + ' use WHO-approved, government-certified, low-toxicity products that are safe for families, children, and pets when applied by our professionals.' },
        { q: 'How do I book pest control in ' + location.name + '?', a: 'You can book pest control in ' + location.name + ' by calling us at ' + phone + ', sending a WhatsApp message, or filling our online contact form. We confirm appointments within 30 minutes.' }
      ]; %>
      <% locationFaqs.forEach(function(item, i) { %>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <button class="faq-question" aria-expanded="false" aria-controls="faq-loc-<%= i %>" itemprop="name">
          <span><%= item.q %></span>
          <span class="faq-icon" aria-hidden="true">+</span>
        </button>
        <div class="faq-answer" id="faq-loc-<%= i %>" hidden itemscope itemtype="https://schema.org/Answer">
          <p itemprop="text"><%= item.a %></p>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Map -->
<% var mapEmbedUrl = location.mapEmbed; %>
<%- include('../partials/google-map') %>

<!-- CTA 3 -->
<% ctaVariant = 'tertiary'; ctaLocation = location.name; %>
<%- include('../partials/cta') %>

<!-- Nearby Locations -->
<section class="section-pad bg-light">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Nearby Services</p>
      <h2 class="section-title">Pest Control in Nearby Cities</h2>
    </div>
    <div class="location-nearby">
      <% locations.filter(l => l.slug !== location.slug).slice(0, 20).forEach(function(loc) { %>
      <a href="/pest-control-in/<%= loc.slug %>" class="location-card">
        <div class="location-card-pin">📍</div>
        <div class="location-card-info">
          <h3 class="location-name"><%= loc.name %></h3>
          <p class="location-state"><%= loc.state %></p>
        </div>
        <span class="location-arrow">→</span>
      </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- Clients -->
<%- include('../partials/clients') %>

<!-- Reviews -->
<%- include('../partials/reviews') %>

<!-- Final CTA -->
<% ctaVariant = 'primary'; %>
<%- include('../partials/cta') %>

<%- include('../partials/footer') %>
