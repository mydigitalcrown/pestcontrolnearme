<!-- How We Work Process -->
<section class="process-section section-pad">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Our Process</p>
      <h2 class="section-title">How Our Pest Control Works</h2>
      <p class="section-desc">A simple, transparent 4-step process to make your property pest-free.</p>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">1</div>
        <div class="step-icon">📞</div>
        <h3 class="step-title">Book Appointment</h3>
        <p class="step-desc">Call us or fill our online form. Get a free consultation and instant quote within 30 minutes.</p>
      </div>
      <div class="process-step">
        <div class="step-number">2</div>
        <div class="step-icon">🔍</div>
        <h3 class="step-title">Free Inspection</h3>
        <p class="step-desc">Our certified technician visits your property for a thorough pest inspection and risk assessment.</p>
      </div>
      <div class="process-step">
        <div class="step-number">3</div>
        <div class="step-icon">🔬</div>
        <h3 class="step-title">Professional Treatment</h3>
        <p class="step-desc">We apply targeted, eco-friendly treatments using advanced pest management techniques.</p>
      </div>
      <div class="process-step">
        <div class="step-number">4</div>
        <div class="step-icon">🛡️</div>
        <h3 class="step-title">3-Month Guarantee</h3>
        <p class="step-desc">Enjoy pest-free living backed by our 3-month service guarantee. We return if pests do!</p>
      </div>
    </div>
  </div>
</section>

