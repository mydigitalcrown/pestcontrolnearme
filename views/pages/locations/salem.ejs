</section>

<!-- CTA 2 -->
<% ctaVariant = 'secondary'; ctaLocation = 'Salem'; %>
<%- include('../../partials/cta') %>

<!-- FAQ -->
<section class="faq-section section-pad" aria-label="FAQ">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">FAQs</p>
      <h2 class="section-title">Pest Control in Salem – Frequently Asked Questions</h2>
    </div>
    <div class="faq-wrapper">
      <% var locationFaqs = [
        { q: 'What is the best pest control company in Salem?', a: 'PestControlNearMe is rated the #1 pest control company in Salem with a 4.9-star rating, 200+ certified technicians, and a 3-month service guarantee.' },
        { q: 'How much does pest control cost in Salem?', a: 'Pest control costs in Salem depend on the type of service, property size, and severity of infestation. We offer transparent pricing. Contact us for a free quote.' },
        { q: 'Do you provide same-day pest control service in Salem?', a: 'Yes, we offer same-day pest control in Salem for most treatments. Call us for emergency services.' },
        { q: 'Which areas in Salem do you cover?', a: 'We cover all areas across Salem and surrounding regions including residential, commercial, and industrial zones.' },
        { q: 'Is your pest control service safe for kids and pets in Salem?', a: 'Yes! All treatments in Salem use WHO-approved, government-certified, low-toxicity products that are safe for families, children, and pets.' },
        { q: 'How do I book pest control in Salem?', a: 'Call us, WhatsApp us, or fill the online form above. We confirm appointments in Salem within 30 minutes.' }
      ]; %>
      <% locationFaqs.forEach(function(item, i) { %>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <button class="faq-question" aria-expanded="false" aria-controls="faq-<%= i %>" itemprop="name">
          <span><%= item.q %></span>
          <span class="faq-icon" aria-hidden="true">+</span>
        </button>
        <div class="faq-answer" id="faq-<%= i %>" hidden itemscope itemtype="https://schema.org/Answer">
          <p itemprop="text"><%= item.a %></p>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

