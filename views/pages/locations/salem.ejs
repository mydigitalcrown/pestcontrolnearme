        <div class="service-card-icon"><%= svc.icon %></div>
        <div class="service-card-body">
          <h3 class="service-card-title" itemprop="name"><%= svc.name %> in Salem</h3>
          <p class="service-card-desc" itemprop="description"><%= svc.shortDesc %></p>
        </div>
        <a href="/services/<%= svc.slug %>" class="service-card-link btn btn-outline" aria-label="<%= svc.name %> in Salem">Know More →</a>
