</div>

<!-- About Section -->
<%- include('../../partials/about-section') %>

<!-- Services in Delhi -->
<section class="services-section section-pad bg-light" aria-label="Services in Delhi">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Our Services</p>
      <h2 class="section-title">Pest Control Services in Delhi</h2>
      <p class="section-desc">Complete pest management for homes and businesses in Delhi, Delhi NCR.</p>
    </div>
    <div class="services-grid">
      <% services.forEach(function(svc) { %>
      <article class="service-card" itemscope itemtype="https://schema.org/Service">
        <div class="service-card-icon"><%= svc.icon %></div>
        <div class="service-card-body">
          <h3 class="service-card-title" itemprop="name"><%= svc.name %> in Delhi</h3>
          <p class="service-card-desc" itemprop="description"><%= svc.shortDesc %></p>
        </div>
        <a href="/services/<%= svc.slug %>" class="service-card-link btn btn-outline" aria-label="<%= svc.name %> in Delhi">Know More →</a>
      </article>
      <% }); %>
    </div>
  </div>
</section>

<!-- CTA 1 -->
<% locals.ctaVariant = 'primary'; locals.ctaLocation = 'Delhi'; %>
<%- include('../../partials/cta') %>

<!-- Location Content -->
<section class="section-pad">
  <div class="container">
    <div class="content-grid">
      <div class="content-main">
        <h2>Pest Control in Delhi, Delhi NCR</h2>
        <p>As India's capital, Delhi's dense urban landscape and varied climate make professional pest control essential for homes and businesses.</p>
        <p>PestControlNearMe provides professional pest management services across all areas of Delhi. Our team of certified technicians is well-acquainted with the pest pressures specific to Delhi's climate, building types, and urban environment.</p>

        <h3>Why Pest Control is Important in Delhi?</h3>
        <p>With a population of approximately 3.2 Crore, Delhi presents unique pest management challenges. Dense urban living, humid climate, and rapid construction activity create ideal conditions for cockroaches, termites, mosquitoes, rodents, and other pests to thrive.</p>

        <h3>Areas We Serve in Delhi</h3>
        <p>Our technicians serve all residential societies, commercial complexes, and industrial areas across Delhi and surrounding areas. Same-day service is available for most locations in the city.</p>

        <h3>What Makes Our Service Different in Delhi?</h3>
        <ul>
          <li>Local experts with deep knowledge of Delhi's pest characteristics</li>
          <li>Treatments customised for Delhi's specific climate and building types</li>
          <li>Fast response – most bookings confirmed within 30 minutes</li>
          <li>All services come with a 3-month guarantee</li>
          <li>Transparent pricing – no hidden charges</li>
        </ul>
      </div>
      <div>
        <div class="why-choose-box">
          <h3>Book Pest Control in Delhi</h3>
          <%- include('../../partials/contact-form', { compact: true }) %>
        </div>
        <div class="why-choose-box" style="margin-top:1.5rem;">
          <h3>Quick Info – Delhi</h3>
          <ul class="why-list">
            <li><span>🏙️</span> Delhi, Delhi NCR</li>
            <li><span>👥</span> Population: ~3.2 Crore</li>
            <li><span>⚡</span> Same-Day Service Available</li>
            <li><span>🛡️</span> 3-Month Guarantee</li>
            <li><span>💰</span> Best Price In Delhi</li>
            <li><span>📞</span> 24/7 Emergency Support</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA 2 -->
<% ctaVariant = 'secondary'; ctaLocation = 'Delhi'; %>
<%- include('../../partials/cta') %>

<!-- FAQ -->
<section class="faq-section section-pad" aria-label="FAQ">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">FAQs</p>
      <h2 class="section-title">Pest Control in Delhi – Frequently Asked Questions</h2>
    </div>
    <div class="faq-wrapper">
      <% var locationFaqs = [
        { q: 'What is the best pest control company in Delhi?', a: 'PestControlNearMe is rated the #1 pest control company in Delhi with a 4.9-star rating, 200+ certified technicians, and a 3-month service guarantee.' },
        { q: 'How much does pest control cost in Delhi?', a: 'Pest control costs in Delhi depend on the type of service, property size, and severity of infestation. We offer transparent pricing. Contact us for a free quote.' },
        { q: 'Do you provide same-day pest control service in Delhi?', a: 'Yes, we offer same-day pest control in Delhi for most treatments. Call us for emergency services.' },
        { q: 'Which areas in Delhi do you cover?', a: 'We cover all areas across Delhi and surrounding regions including residential, commercial, and industrial zones.' },
        { q: 'Is your pest control service safe for kids and pets in Delhi?', a: 'Yes! All treatments in Delhi use WHO-approved, government-certified, low-toxicity products that are safe for families, children, and pets.' },
        { q: 'How do I book pest control in Delhi?', a: 'Call us, WhatsApp us, or fill the online form above. We confirm appointments in Delhi within 30 minutes.' }
      ]; %>
      <% locationFaqs.forEach(function(item, i) { %>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <button class="faq-question" aria-expanded="false" aria-controls="faq-<%= i %>" itemprop="name">
          <span><%= item.q %></span>
          <span class="faq-icon" aria-hidden="true">+</span>
        </button>
        <div class="faq-answer" id="faq-<%= i %>" hidden itemscope itemtype="https://schema.org/Answer">
          <p itemprop="text"><%= item.a %></p>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Google Map -->
<% locals.mapEmbedUrl = 'https://maps.google.com/maps?q=Delhi,India&output=embed'; locals.mapLocation = 'Delhi'; %>
<%- include('../../partials/google-map') %>

