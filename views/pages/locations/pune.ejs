    <div class="trust-item"><strong>4.9 ★</strong><span>Rated in Pune</span></div>
  </div>
</div>

<!-- About Section -->
<%- include('../../partials/about-section') %>

<!-- Services in Pune -->
<section class="services-section section-pad bg-light" aria-label="Services in Pune">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Our Services</p>
      <h2 class="section-title">Pest Control Services in Pune</h2>
      <p class="section-desc">Complete pest management for homes and businesses in Pune, Maharashtra.</p>
    </div>
    <div class="services-grid">
      <% services.forEach(function(svc) { %>
      <article class="service-card" itemscope itemtype="https://schema.org/Service">
        <div class="service-card-icon"><%= svc.icon %></div>
        <div class="service-card-body">
          <h3 class="service-card-title" itemprop="name"><%= svc.name %> in Pune</h3>
          <p class="service-card-desc" itemprop="description"><%= svc.shortDesc %></p>
        </div>
        <a href="/services/<%= svc.slug %>" class="service-card-link btn btn-outline" aria-label="<%= svc.name %> in Pune">Know More →</a>
      </article>
      <% }); %>
    </div>
  </div>
</section>

<!-- CTA 1 -->
<% locals.ctaVariant = 'primary'; locals.ctaLocation = 'Pune'; %>
<%- include('../../partials/cta') %>

<!-- Location Content -->
<section class="section-pad">
  <div class="container">
    <div class="content-grid">
      <div class="content-main">
        <h2>Pest Control in Pune, Maharashtra</h2>
        <p>Pune's growing population and urban expansion have increased the demand for professional pest control services across the city.</p>
        <p>PestControlNearMe provides professional pest management services across all areas of Pune. Our team of certified technicians is well-acquainted with the pest pressures specific to Pune's climate, building types, and urban environment.</p>

        <h3>Why Pest Control is Important in Pune?</h3>
        <p>With a population of approximately 76 Lakh, Pune presents unique pest management challenges. Dense urban living, humid climate, and rapid construction activity create ideal conditions for cockroaches, termites, mosquitoes, rodents, and other pests to thrive.</p>

        <h3>Areas We Serve in Pune</h3>
        <p>Our technicians serve all residential societies, commercial complexes, and industrial areas across Pune and surrounding areas. Same-day service is available for most locations in the city.</p>

        <h3>What Makes Our Service Different in Pune?</h3>
        <ul>
          <li>Local experts with deep knowledge of Pune's pest characteristics</li>
          <li>Treatments customised for Pune's specific climate and building types</li>
          <li>Fast response – most bookings confirmed within 30 minutes</li>
          <li>All services come with a 3-month guarantee</li>
          <li>Transparent pricing – no hidden charges</li>
        </ul>
      </div>
      <div>
        <div class="why-choose-box">
          <h3>Book Pest Control in Pune</h3>
          <%- include('../../partials/contact-form', { compact: true }) %>
        </div>
        <div class="why-choose-box" style="margin-top:1.5rem;">
          <h3>Quick Info – Pune</h3>
          <ul class="why-list">
            <li><span>🏙️</span> Pune, Maharashtra</li>
            <li><span>👥</span> Population: ~76 Lakh</li>
            <li><span>⚡</span> Same-Day Service Available</li>
            <li><span>🛡️</span> 3-Month Guarantee</li>
            <li><span>💰</span> Best Price In Pune</li>
            <li><span>📞</span> 24/7 Emergency Support</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA 2 -->
<% ctaVariant = 'secondary'; ctaLocation = 'Pune'; %>
<%- include('../../partials/cta') %>

<!-- FAQ -->
<section class="faq-section section-pad" aria-label="FAQ">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">FAQs</p>
      <h2 class="section-title">Pest Control in Pune – Frequently Asked Questions</h2>
    </div>
    <div class="faq-wrapper">
      <% var locationFaqs = [
        { q: 'What is the best pest control company in Pune?', a: 'PestControlNearMe is rated the #1 pest control company in Pune with a 4.9-star rating, 200+ certified technicians, and a 3-month service guarantee.' },
        { q: 'How much does pest control cost in Pune?', a: 'Pest control costs in Pune depend on the type of service, property size, and severity of infestation. We offer transparent pricing. Contact us for a free quote.' },
        { q: 'Do you provide same-day pest control service in Pune?', a: 'Yes, we offer same-day pest control in Pune for most treatments. Call us for emergency services.' },
        { q: 'Which areas in Pune do you cover?', a: 'We cover all areas across Pune and surrounding regions including residential, commercial, and industrial zones.' },
        { q: 'Is your pest control service safe for kids and pets in Pune?', a: 'Yes! All treatments in Pune use WHO-approved, government-certified, low-toxicity products that are safe for families, children, and pets.' },
        { q: 'How do I book pest control in Pune?', a: 'Call us, WhatsApp us, or fill the online form above. We confirm appointments in Pune within 30 minutes.' }
      ]; %>
      <% locationFaqs.forEach(function(item, i) { %>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <button class="faq-question" aria-expanded="false" aria-controls="faq-<%= i %>" itemprop="name">
          <span><%= item.q %></span>
          <span class="faq-icon" aria-hidden="true">+</span>
        </button>
        <div class="faq-answer" id="faq-<%= i %>" hidden itemscope itemtype="https://schema.org/Answer">
          <p itemprop="text"><%= item.a %></p>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Google Map -->
<% locals.mapEmbedUrl = 'https://maps.google.com/maps?q=Pune,Maharashtra&output=embed'; locals.mapLocation = 'Pune'; %>
<%- include('../../partials/google-map') %>

<!-- CTA 3 -->
<% ctaVariant = 'tertiary'; ctaLocation = 'Pune'; %>
<%- include('../../partials/cta') %>

<!-- Nearby Locations -->
