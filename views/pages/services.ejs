<%- include('../partials/head') %>
<%- include('../partials/header') %>

<!-- Hero -->
<section class="hero-section" style="min-height:400px;" aria-label="Hero">
  <div class="hero-bg"><div class="hero-overlay"></div></div>
  <div class="container hero-content" style="grid-template-columns:1fr 420px;min-height:400px;padding:3rem 24px;">
    <div class="hero-text">
      <p class="hero-tagline">🛠️ 19 Specialized Pest Control Services</p>
      <h1 class="hero-title"><%= page.heroTitle %></h1>
      <p class="hero-subtitle"><%= page.heroSubtitle %></p>
      <div class="hero-cta-group">
        <a href="tel:<%= phone.replace(/\s/g,'') %>" class="btn btn-primary btn-lg">📞 Call Now</a>
        <a href="/contact" class="btn btn-outline-white btn-lg">📋 Get Free Quote</a>
      </div>
    </div>
    <div class="hero-form-box">
      <h2 class="form-box-title">Book a Service</h2>
      <p class="form-box-sub">Quick response guaranteed!</p>
      <%- include('../partials/contact-form', { compact: true }) %>
    </div>
  </div>
</section>

<!-- Trust Bar -->
<div class="trust-bar">
  <div class="container trust-bar-inner">
    <div class="trust-item"><strong>19</strong><span>Pest Services</span></div>
    <div class="trust-item"><strong>50,000+</strong><span>Customers Served</span></div>
    <div class="trust-item"><strong>3-Month</strong><span>Service Guarantee</span></div>
    <div class="trust-item"><strong>Same-Day</strong><span>Service Available</span></div>
    <div class="trust-item"><strong>4.9 ★</strong><span>Customer Rating</span></div>
  </div>
</div>

<!-- All Services Grid -->
<section class="section-pad" aria-label="All Services">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">All Services</p>
      <h2 class="section-title">Our 19 Professional Pest Control Services</h2>
      <p class="section-desc">From common household pests to rare infestations – we have the expertise, tools, and solutions for every pest problem in India.</p>
    </div>
    <div class="services-grid" style="grid-template-columns:repeat(auto-fill,minmax(290px,1fr));">
      <% services.forEach(function(svc) { %>
      <article class="service-card" itemscope itemtype="https://schema.org/Service">
        <div class="service-card-icon"><%= svc.icon %></div>
        <div class="service-card-body">
          <h3 class="service-card-title" itemprop="name"><%= svc.name %></h3>
          <p class="service-card-desc" itemprop="description"><%= svc.shortDesc %></p>
          <ul class="service-card-features">
            <li>✅ Safe & Eco-Friendly Products</li>
            <li>✅ Certified Technicians</li>
            <li>✅ 3-Month Service Guarantee</li>
            <li>✅ Same-Day Availability</li>
          </ul>
        </div>
        <a href="/services/<%= svc.slug %>" class="service-card-link btn btn-primary" 
          itemprop="url" aria-label="Learn about <%= svc.name %> services">
          Know More & Book →
        </a>
      </article>
      <% }); %>
    </div>
  </div>
</section>

<!-- How We Work -->
<section class="process-section section-pad bg-light">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Our Process</p>
      <h2 class="section-title">How Our Pest Control Process Works</h2>
    </div>
    <div class="process-steps">
      <div class="process-step"><div class="step-number">1</div><div class="step-icon">📞</div><h3 class="step-title">Book Appointment</h3><p class="step-desc">Call, WhatsApp or fill our form for a free consultation and instant quote.</p></div>
      <div class="process-step"><div class="step-number">2</div><div class="step-icon">🔍</div><h3 class="step-title">Free Inspection</h3><p class="step-desc">Our certified technician inspects your property and identifies pest species and extent of infestation.</p></div>
      <div class="process-step"><div class="step-number">3</div><div class="step-icon">🔬</div><h3 class="step-title">Expert Treatment</h3><p class="step-desc">We apply targeted, eco-friendly treatments using the most advanced pest management methods.</p></div>
      <div class="process-step"><div class="step-number">4</div><div class="step-icon">🛡️</div><h3 class="step-title">3-Month Guarantee</h3><p class="step-desc">Backed by our service guarantee – we return free if pests come back within 3 months.</p></div>
    </div>
  </div>
</section>

<!-- CTA -->
<% var ctaVariant = 'primary'; var ctaLocation = 'Mumbai'; %>
<%- include('../partials/cta') %>

<!-- FAQ -->
<%- include('../partials/faq-section') %>

<!-- Reviews -->
<%- include('../partials/reviews') %>

<!-- Final CTA -->
<% ctaVariant = 'secondary'; %>
<%- include('../partials/cta') %>

<%- include('../partials/footer') %>
