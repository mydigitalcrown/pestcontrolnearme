<!-- GOOGLE MAP SECTION COMPONENT -->
<% var mapLoc = (typeof mapLocation !== 'undefined' && mapLocation) ? mapLocation : (typeof heroLocation !== 'undefined' && heroLocation) ? heroLocation : 'Mumbai'; %>
<% var mapEmbedUrl = (typeof mapEmbed !== 'undefined' && mapEmbed) ? mapEmbed : (typeof page !== 'undefined' && page.mapEmbed) ? page.mapEmbed : 'https://maps.google.com/maps?q=Mumbai,Maharashtra&output=embed'; %>
<section class="map-section section-pad bg-light" aria-label="Our Location on Map">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Find Us</p>
      <h2 class="section-title">Pest Control Services Near You in <%= mapLoc %></h2>
      <p class="section-desc">We serve all areas of <%= mapLoc %> and surrounding regions. Find our service area on the map below.</p>
    </div>
    <div class="map-wrapper">
      <div class="map-info-bar">
        <div class="map-info-item">
          <span class="map-info-icon">📍</span>
          <div>
            <strong>Office Location</strong>
            <p>Mumbai, Maharashtra – 400001</p>
          </div>
        </div>
        <div class="map-info-item">
          <span class="map-info-icon">⏰</span>
          <div>
            <strong>Working Hours</strong>
            <p>Monday – Sunday: 6:00 AM – 10:00 PM</p>
          </div>
        </div>
        <div class="map-info-item">
          <span class="map-info-icon">📞</span>
          <div>
            <strong>Phone Numbers</strong>
            <p><a href="tel:<%= phone.replace(/\s/g,'') %>"><%= phone %></a></p>
          </div>
        </div>
        <div class="map-info-item">
          <span class="map-info-icon">✉️</span>
          <div>
            <strong>Email Address</strong>
            <p><a href="mailto:<%= email %>"><%= email %></a></p>
          </div>
        </div>
      </div>
      <div class="map-embed-container">
        <iframe 
          src="<%= mapEmbedUrl %>"
          width="100%" 
          height="450" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          title="Pest Control Services in <%= mapLoc %> – Map"
          aria-label="Map showing pest control service area in <%= mapLoc %>">
        </iframe>
      </div>
    </div>
  </div>
</section>
