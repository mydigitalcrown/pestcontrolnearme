<!-- ABOUT SECTION COMPONENT -->
<section class="about-section section-pad" aria-label="About Us">
  <div class="container">
    <div class="about-grid">
      <div class="about-image-col">
        <div class="about-image-wrap">
          <img src="/images/about-team.jpg" 
            alt="Professional pest control team in <%= typeof heroLocation !== 'undefined' ? heroLocation : 'Mumbai' %>"
            width="580" height="440" loading="lazy"
            onerror="this.src='/images/placeholder-about.jpg'">
          <div class="about-badge-float">
            <div class="float-badge">
              <span class="badge-num">10+</span>
              <span class="badge-label">Years of Trusted Service</span>
            </div>
          </div>
        </div>
        <div class="about-certifications">
          <span class="cert-tag">🏅 ISO Certified</span>
          <span class="cert-tag">✅ Govt. Approved</span>
          <span class="cert-tag">🔬 CIB Registered</span>
          <span class="cert-tag">⭐ 4.9 / 5 Rating</span>
        </div>
      </div>
      <div class="about-content-col">
        <p class="section-tag">About Us</p>
        <h2 class="section-title">Mumbai's Most Trusted Pest Control Since 2014</h2>
        <p class="about-text">
          PestControlNearMe is India's leading professional pest management company, headquartered in Mumbai with service operations across 55+ cities. 
          For over a decade, we have protected homes, offices, restaurants, hospitals, and industrial facilities from all types of pest infestations.
        </p>
        <p class="about-text">
          Our team of 200+ certified pest control technicians uses the latest eco-friendly products and advanced pest management techniques approved by the Central Insecticides Board (CIB) and government authorities.
        </p>
        <div class="about-features">
          <div class="feature-item">
            <span class="feature-icon">🏆</span>
            <div>
              <strong>Award-Winning Service</strong>
              <p>Recognized as Best Pest Control Service Provider in Maharashtra 2023.</p>
            </div>
          </div>
          <div class="feature-item">
            <span class="feature-icon">🔬</span>
            <div>
              <strong>Scientific Approach</strong>
              <p>IPM (Integrated Pest Management) methodology for long-lasting results.</p>
            </div>
          </div>
          <div class="feature-item">
            <span class="feature-icon">🌿</span>
            <div>
              <strong>Eco-Friendly Products</strong>
              <p>WHO-approved, low-toxicity chemicals safe for children, pets and the environment.</p>
            </div>
          </div>
          <div class="feature-item">
            <span class="feature-icon">🛡️</span>
            <div>
              <strong>Service Guarantee</strong>
              <p>We back every service with a 3-month guarantee – free re-treatment if needed.</p>
            </div>
          </div>
        </div>
        <a href="/about" class="btn btn-primary">Learn More About Us →</a>
      </div>
    </div>
  </div>
</section>
