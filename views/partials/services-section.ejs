<!-- SERVICES SECTION COMPONENT -->
<% var sectionLocation = (typeof heroLocation !== 'undefined' && heroLocation) ? heroLocation : 'Mumbai'; %>
<%
var serviceImages = {
  'cockroach-control': 'Cockroach.png',
  'termite-control': 'Termite.png',
  'mosquito-control': 'Mosquito.png',
  'rodent-control': 'Rodent.png',
  'bed-bug-control': 'Bed-Bug.png',
  'ant-control': 'Ant.png',
  'fly-control': 'Fly.png',
  'lizard-control': 'Lizard.png',
  'spider-control': 'Spider.png',
  'wasp-bee-control': 'Wasp-Bee.png',
  'wood-borer-control': 'Wood-Borer.png',
  'bird-control': 'Bird.png',
  'snake-control': 'Snake.png',
  'silverfish-control': 'Silverfish.png',
  'stored-product-pest-control': 'Stored-Product.png',
  'general-pest-control': 'General-Pest-Control.png',
  'dog-tick-control': 'Dog-ticks.png',
  'eco-friendly-pest-control': 'ecofriendly-pest-control.png',
  'herbal-pest-control': 'herbal-pest-control.png'
};
%>
<section class="services-section section-pad bg-light" aria-label="Our Services">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">What We Do</p>
      <h2 class="section-title">Complete Pest Control Services in <%= sectionLocation %></h2>
      <p class="section-desc">We offer 19 specialized pest control services to protect your home and business from every type of pest infestation.</p>
    </div>
    <div class="services-grid">
      <% services.forEach(function(svc) { %>
      <% var svcImg = serviceImages[svc.slug]; %>
      <article class="service-card" itemscope itemtype="https://schema.org/Service">
        <div class="service-card-img-wrap">
          <% if (svcImg) { %>
            <img src="/images/<%= svcImg %>" alt="<%= svc.name %>" class="service-card-img" loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="service-card-icon-fallback" style="display:none"><%= svc.icon %></div>
          <% } else { %>
            <div class="service-card-icon-fallback"><%= svc.icon %></div>
          <% } %>
        </div>
        <div class="service-card-body">
          <h3 class="service-card-title" itemprop="name"><%= svc.name %></h3>
          <p class="service-card-desc" itemprop="description"><%= svc.shortDesc %></p>
          <ul class="service-card-features">
            <li>✅ Certified Technicians</li>
            <li>✅ 3-Month Guarantee</li>
            <li>✅ Same-Day Service</li>
          </ul>
        </div>
        <a href="/services/<%= svc.slug %>" class="service-card-link btn btn-outline"
          itemprop="url" aria-label="Learn more about <%= svc.name %> in <%= sectionLocation %>">
          Know More →
        </a>
      </article>
      <% }); %>
    </div>
    <div class="text-center mt-4">
      <a href="/services" class="btn btn-primary btn-lg">View All 19 Services</a>
    </div>
  </div>
</section>
