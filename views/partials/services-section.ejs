<!-- SERVICES SECTION COMPONENT -->
<% var sectionLocation = (typeof heroLocation !== 'undefined' && heroLocation) ? heroLocation : 'Mumbai'; %>
<section class="services-section section-pad bg-light" aria-label="Our Services">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">What We Do</p>
      <h2 class="section-title">Complete Pest Control Services in <%= sectionLocation %></h2>
      <p class="section-desc">We offer 16 specialized pest control services to protect your home and business from every type of pest infestation.</p>
    </div>
    <div class="services-grid">
      <% services.forEach(function(svc) { %>
      <article class="service-card" itemscope itemtype="https://schema.org/Service">
        <div class="service-card-icon"><%= svc.icon %></div>
        <div class="service-card-body">
          <h3 class="service-card-title" itemprop="name"><%= svc.name %></h3>
          <p class="service-card-desc" itemprop="description"><%= svc.shortDesc %></p>
          <ul class="service-card-features">
            <li>✅ Certified Technicians</li>
            <li>✅ 3-Month Guarantee</li>
            <li>✅ Same-Day Service</li>
          </ul>
        </div>
        <a href="/services/<%= svc.slug %>" class="service-card-link btn btn-outline" 
          itemprop="url" aria-label="Learn more about <%= svc.name %> in <%= sectionLocation %>">
          Know More →
        </a>
      </article>
      <% }); %>
    </div>
    <div class="text-center mt-4">
      <a href="/services" class="btn btn-primary btn-lg">View All 16 Services</a>
    </div>
  </div>
</section>
