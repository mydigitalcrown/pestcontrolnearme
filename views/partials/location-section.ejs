<!-- LOCATION SECTION COMPONENT -->
<section class="location-section section-pad" aria-label="Our Service Locations">
  <div class="container">
    <div class="section-header text-center">
      <p class="section-tag">Where We Serve</p>
      <h2 class="section-title">Pest Control Services Across India</h2>
      <p class="section-desc">Professional pest control in 55+ cities across India. Find expert pest management near you.</p>
    </div>
    <div class="location-grid">
      <% locations.forEach(function(loc) { %>
      <a href="/pest-control-in/<%= loc.slug %>" class="location-card" 
        aria-label="Pest Control in <%= loc.name %>, <%= loc.state %>">
        <div class="location-card-pin">📍</div>
        <div class="location-card-info">
          <h3 class="location-name"><%= loc.name %></h3>
          <p class="location-state"><%= loc.state %></p>
        </div>
        <span class="location-arrow">→</span>
      </a>
      <% }); %>
    </div>
    <div class="text-center mt-4">
      <a href="/locations" class="btn btn-primary">View All 55+ Locations</a>
    </div>
  </div>
</section>
